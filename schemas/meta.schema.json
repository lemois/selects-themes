{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://selects-themes.local/schemas/meta.schema.json",
  "title": "Theme Metadata",
  "type": "object",
  "required": ["name"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    },
    "unlisted": {
      "type": "boolean"
    }
  },
  "additionalProperties": false
}
